# Copy this file to .env and fill values locally or in EC2 UserData/Secrets Manager.

DJANGO_SECRET_KEY=replace-with-your-django-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=whatmyname.click,www.whatmyname.click,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://whatmyname.click,https://www.whatmyname.click
DJANGO_SITE_ID=2

DB_NAME=academy_db
DB_USER=admin
DB_PASSWORD=replace-with-db-password
DB_MASTER_HOST=replace-with-rds-writer-endpoint
DB_SLAVE_HOST=replace-with-rds-reader-endpoint
DB_PORT=3306

AWS_STORAGE_BUCKET_NAME=replace-with-s3-bucket-name
AWS_S3_REGION_NAME=ap-northeast-2
AWS_REGION=ap-northeast-2

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-with-email-account
EMAIL_HOST_PASSWORD=replace-with-email-app-password
DEFAULT_FROM_EMAIL=replace-with-email-account

DJANGO_ENABLE_XRAY=False
AWS_XRAY_TRACING_NAME=tikitaka-app
